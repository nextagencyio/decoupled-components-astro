{
  "name": "decoupled-components-astro",
  "version": "0.1.0",
  "description": "Astro starter template for Decoupled.io - headless Drupal with visual editor",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "setup": "npx decoupled-cli@latest setup --content data/components-content.json",
    "setup-content": "npx decoupled-cli@latest content import --file data/components-content.json",
    "setup-content:preview": "npx decoupled-cli@latest content import --file data/components-content.json --preview",
    "sync-schema": "npx decoupled-cli@latest schema sync"
  },
  "dependencies": {
    "@astrojs/netlify": "^6.6.5",
    "@astrojs/node": "^9.1.3",
    "@astrojs/react": "^4.3.1",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^9.0.5",
    "@puckeditor/cloud-client": "^0.6.0",
    "@puckeditor/core": "^0.21.1",
    "@puckeditor/plugin-ai": "^0.6.0",
    "@tailwindcss/typography": "^0.5.16",
    "astro": "^5.8.0",
    "clsx": "^2.1.1",
    "decoupled-client": "^0.2.0",
    "dotenv": "^17.2.1",
    "lucide-react": "^0.539.0",
    "puck-plugin-ai": "^0.2.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "autoprefixer": "^10.4.20",
    "decoupled-cli": "^2.9.9",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
