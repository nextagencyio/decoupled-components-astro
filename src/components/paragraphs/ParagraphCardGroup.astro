---
import { clsx } from 'clsx'
import type { ParagraphCardGroup as ParagraphCardGroupType, Card as CardType } from '@/lib/types'
import Card from '../ui/Card.astro'
import Badge from '../ui/Badge.astro'
import Button from '../ui/Button.astro'

interface Props extends ParagraphCardGroupType {}

const { eyebrow, title, subtitle, columns = '3', cards } = Astro.props

const gridCols: Record<string, string> = {
  '2': 'md:grid-cols-2',
  '3': 'md:grid-cols-3',
  '4': 'md:grid-cols-2 lg:grid-cols-4',
}
---

<section class="section-padding bg-white" id="features">
  <div class="container-wide">
    {(eyebrow || title || subtitle) && (
      <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
        {eyebrow && (
          <Badge variant="primary" class="mb-4">
            {eyebrow}
          </Badge>
        )}
        {title && (
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            {title}
          </h2>
        )}
        {subtitle && (
          <p class="text-lg text-gray-600">{subtitle}</p>
        )}
      </div>
    )}

    {Array.isArray(cards) && cards.length > 0 ? (
      <div class={clsx('grid gap-6 md:gap-8', gridCols[columns])}>
        {cards.map((card: CardType) => (
          <Card variant="bordered" class="h-full hover:border-primary-200 hover:shadow-md transition-all">
            {card.icon && (
              <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-4">
                <span class="text-primary-600 text-lg font-bold">{card.icon.charAt(0)}</span>
              </div>
            )}
            <div class="mb-4">
              <h3 class="font-semibold text-gray-900 text-xl">{card.title}</h3>
            </div>
            <div class="text-gray-600">
              {card.description && (
                <p class="text-gray-600 mb-4">{card.description}</p>
              )}
              {card.linkText && card.linkUrl && (
                <a href={card.linkUrl} class="text-primary-600 hover:text-primary-700 font-semibold">
                  {card.linkText} &rarr;
                </a>
              )}
            </div>
          </Card>
        ))}
      </div>
    ) : (
      <div class="text-center py-8 text-gray-500">
        <p>No cards configured. Add cards in the Drupal admin.</p>
      </div>
    )}
  </div>
</section>
