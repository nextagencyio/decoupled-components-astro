---
import { clsx } from 'clsx'
import type { ParagraphSidebyside as ParagraphSidebysideType } from '@/lib/types'
import Badge from '../ui/Badge.astro'
import Button from '../ui/Button.astro'

interface Props extends ParagraphSidebysideType {}

const {
  eyebrow,
  title,
  content,
  image,
  imagePosition = 'right',
  features,
  ctaText,
  ctaUrl,
} = Astro.props

const isImageLeft = imagePosition === 'left'

function secureUrl(url: string): string {
  return url.replace(/^http:\/\//, 'https://')
}
---

<section class="section-padding bg-white">
  <div class="container-wide">
    <div
      class={clsx(
        'grid md:grid-cols-2 gap-12 md:gap-16 items-center',
        isImageLeft && 'md:flex-row-reverse'
      )}
    >
      <div class={clsx(isImageLeft && 'md:order-2')}>
        {eyebrow && (
          <Badge variant="primary" class="mb-4">
            {eyebrow}
          </Badge>
        )}
        {title && (
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            {title}
          </h2>
        )}
        {content && (
          <div class="prose prose-lg text-gray-600 mb-8" set:html={content} />
        )}

        {Array.isArray(features) && features.length > 0 && (
          <ul class="space-y-4 mb-8">
            {features.map((feature) => (
              <li class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">{feature.title}</h3>
                  {feature.description && (
                    <p class="text-gray-600 text-sm">{feature.description}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>
        )}

        {ctaText && ctaUrl && (
          <Button variant="primary" href={ctaUrl}>
            {ctaText}
          </Button>
        )}
      </div>

      <div
        class={clsx(
          'relative aspect-square md:aspect-auto md:h-[500px] rounded-2xl overflow-hidden bg-gray-100',
          isImageLeft && 'md:order-1'
        )}
      >
        {image?.url ? (
          <img
            src={secureUrl(image.url)}
            alt={image.alt || title || ''}
            class="absolute inset-0 w-full h-full object-cover"
          />
        ) : (
          <div class="absolute inset-0 bg-gradient-to-br from-primary-100 to-secondary-100 flex items-center justify-center">
            <div class="w-24 h-24 bg-white/50 rounded-2xl flex items-center justify-center">
              <svg class="w-12 h-12 text-primary-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="m21 15-5-5L5 21" />
              </svg>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
