---
const footerLinks = {
  product: [
    { name: 'Features', href: '/#features' },
    { name: 'Pricing', href: '/#pricing' },
    { name: 'About', href: '/about' },
  ],
  resources: [
    { name: 'Documentation', href: 'https://decoupled.io/docs' },
    { name: 'GitHub', href: 'https://github.com/nextagencyio' },
  ],
}

const currentYear = new Date().getFullYear()
---

<footer class="bg-gray-900 text-gray-300">
  <div class="container-wide py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8">
      <div class="col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
              <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
              <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
              <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
            </svg>
          </div>
          <span class="font-bold text-xl text-white">LaunchPad</span>
        </a>
        <p class="text-sm text-gray-400 mb-6 max-w-xs">
          The platform built for modern teams to ship products faster.
        </p>
        <div class="flex gap-4">
          <!-- GitHub -->
          <a href="https://github.com" class="text-gray-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">
            <span class="sr-only">GitHub</span>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
          <!-- Twitter -->
          <a href="https://twitter.com" class="text-gray-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">
            <span class="sr-only">Twitter</span>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://linkedin.com" class="text-gray-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">
            <span class="sr-only">LinkedIn</span>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="font-semibold text-white mb-4">Product</h3>
        <ul class="space-y-3">
          {footerLinks.product.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-white mb-4">Resources</h3>
        <ul class="space-y-3">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-400">
        &copy; {currentYear} LaunchPad. All rights reserved.
      </p>
      <p class="text-sm text-gray-400">
        Built with{' '}
        <a
          href="https://decoupled.io"
          class="text-primary-400 hover:text-primary-300"
          target="_blank"
          rel="noopener noreferrer"
        >
          Decoupled.io
        </a>
        {' '}&amp;{' '}
        <a
          href="https://astro.build"
          class="text-primary-400 hover:text-primary-300"
          target="_blank"
          rel="noopener noreferrer"
        >
          Astro
        </a>
      </p>
    </div>
  </div>
</footer>
