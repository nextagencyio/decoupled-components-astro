---
/**
 * Header dispatcher.
 *
 * Reads the chosen preset from /api/dc-chrome/settings at build time and
 * renders one of four layout components. Keeps the public contract
 * (`<Header />`) identical so pages don't change when the preset does.
 */
import { getChromeConfig } from '@/lib/chrome'
import HeaderLogoNavCtaRight   from './header/HeaderLogoNavCtaRight.astro'
import HeaderCenteredLogo      from './header/HeaderCenteredLogo.astro'
import HeaderLogoLeftNavRight  from './header/HeaderLogoLeftNavRight.astro'
import HeaderMinimalCta        from './header/HeaderMinimalCta.astro'

const chrome = await getChromeConfig()
const preset = chrome.header.preset
---

{preset === 'centered_logo' && <HeaderCenteredLogo />}
{preset === 'logo_left_nav_right' && <HeaderLogoLeftNavRight />}
{preset === 'minimal_cta' && <HeaderMinimalCta />}
{(preset === 'logo_nav_cta_right' || !['centered_logo','logo_left_nav_right','minimal_cta'].includes(preset)) && <HeaderLogoNavCtaRight />}
