---
import SiteLayout from '@/src/layouts/SiteLayout.astro'
---

<SiteLayout title="Page Not Found">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-gray-900 mb-4">404</h1>
      <p class="text-xl text-gray-600 mb-8">Page not found</p>
      <a
        href="/"
        class="inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 bg-primary-600 text-white hover:bg-primary-700 px-7 py-3.5 text-lg"
      >
        Go Home
      </a>
    </div>
  </div>
</SiteLayout>
